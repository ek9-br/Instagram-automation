{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://post-automation-agent/schemas/post-request.schema.json",
  "title": "PostRequest",
  "description": "Job de geração de post recebido pelo worker local (futuramente enviado por uma edge function do Supabase).",
  "type": "object",
  "additionalProperties": false,
  "required": ["job_id", "brand", "format", "briefing", "objective", "audience"],
  "properties": {
    "job_id": {
      "type": "string",
      "description": "Identificador único do job (UUID).",
      "pattern": "^[0-9a-fA-F-]{8,}$"
    },
    "brand": {
      "type": "string",
      "description": "Nome da marca, deve corresponder a uma marca em brand_bible.md.",
      "minLength": 1
    },
    "format": {
      "type": "string",
      "description": "Formato da peça.",
      "enum": [
        "post_feed_3x4",
        "post_feed_1x1",
        "carousel_3x4",
        "carousel_1x1",
        "stories_9x16",
        "reels_cover_9x16",
        "ads_landscape_1_91_1"
      ]
    },
    "briefing": {
      "type": "string",
      "description": "Briefing livre descrevendo o que se deseja comunicar.",
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "description": "Objetivo de marketing do post.",
      "enum": ["awareness", "engagement", "conversion", "education", "retention"]
    },
    "audience": {
      "type": "string",
      "description": "Persona/ICP alvo (nome ou descrição), referenciando personas.md.",
      "minLength": 1
    }
  }
}
