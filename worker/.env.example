# Configuração do worker local. Copie para `.env` e preencha.

# URL do projeto Supabase (ex.: https://xxxx.supabase.co)
SUPABASE_URL=

# Service role key (Project Settings → API). Ignora RLS — mantenha local/secreto.
SUPABASE_SERVICE_ROLE_KEY=

# Intervalo de polling em ms (opcional, padrão 5000)
POLL_INTERVAL_MS=5000

# Caminho do binário do Claude Code (opcional; padrão usa o `claude` do PATH).
# Útil quando o PATH não inclui o npm-global. Ex.:
# CLAUDE_BIN=/Users/voce/.npm-global/bin/claude
CLAUDE_BIN=

# Chave da API Anthropic — necessária porque o worker invoca o `claude` em modo
# headless. Em organizações que desabilitam o acesso por assinatura no Claude
# Code, a API key é obrigatória. Gere em https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Pasta do Drive de destino dos Docs gerados
DRIVE_FOLDER_ID=

# Web App (Apps Script) que grava link+status na planilha de pautas
# (ver worker/apps-script-sheet-writer.gs): URL da implantação + o mesmo TOKEN do script.
SHEET_WEBHOOK_URL=
SHEET_WEBHOOK_TOKEN=
