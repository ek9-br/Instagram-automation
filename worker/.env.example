# Configuração do worker local de posts. Copie para `.env` e preencha.

# URL do projeto Supabase (ex.: https://xxxx.supabase.co)
SUPABASE_URL=

# Service role key (Project Settings → API). Ignora RLS — mantenha local/secreto.
SUPABASE_SERVICE_ROLE_KEY=

# Intervalo de polling em ms (opcional, padrão 5000)
POLL_INTERVAL_MS=5000

# Caminho do binário do Claude Code (opcional; padrão usa o `claude` do PATH).
# Útil quando o PATH não inclui o npm-global. Ex.:
# CLAUDE_BIN=/Users/voce/.npm-global/bin/claude
CLAUDE_BIN=

# Chave da API Anthropic — necessária se o `claude` headless não estiver autenticado
# por assinatura. Gere em https://console.anthropic.com/ (opcional).
ANTHROPIC_API_KEY=

# Geração de imagens: se "true", após o pipeline o worker chama a edge function
# `generate-image` para cada image_prompt e anexa a URL gerada à response.
# Requer a function deployada e OPENAI_API_KEY setada como secret no Supabase.
GENERATE_IMAGES=false

# URL da edge function de imagem (opcional; padrão = $SUPABASE_URL/functions/v1/generate-image)
IMAGE_FN_URL=
